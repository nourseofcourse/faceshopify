<!-- /templates/collection.liquid -->
{% comment %}

  For more information on collection tags:
    - http://docs.shopify.com/themes/liquid-variables/collection

{% endcomment %}

{% assign rows = settings.home_featured_products_row_num %}
{% assign products_number = rows | times: 3 %}

{% paginate collection.products by products_number %}


{% include 'small-header' %}
{% include 'collection-sorting' %}

{% comment %}
  Loop through our products in the current collection.
  See the snippet 'product-grid-item' for the layout.
{% endcomment %}

{% if settings.collection_sidebar and settings.collection_sidebar_sort_by or settings.collection_sidebar_tags %}
<div class="container">
  <div class="row">
    <div class="col-md-3">
        {% include 'collection-sidebar' %}
    </div>
    
    <div class="col-md-9">
      {% if settings.grid_list_full == 'grid' %}
        <section class="products-grid">
          <div class="container-fluid">
            <div class="row">
              <div class="col-md-12">
                <div class="section-title">
                  <div class="title-sep-container title-sep-container-left">
                    <div class="title-sep"></div>
                  </div>
                  <h2 class="page-title h1-size text-center">{{ collection.title }}</h2>
                  <div class="title-sep-container title-sep-container-right">
                    <div class="title-sep"></div>
                  </div>
                </div>
                <p class="section-subtitle">{{ collection.description | truncate: 100}}</p>
              </div>
            </div>
            <div class="row products-container">
                {% if settings.grid_type == 'overlay' %}
                  {% for product in collection.products %}
                      {% include 'product-grid-item2' %}
                  {% else %}
                    {% comment %}
                      For onboarding new users to your theme, we add some default products and onboarding tutorials to help populate their store
                    {% endcomment %}
                    {% unless emptyState %}
                      {{ 'theme-onboarding.css' | global_asset_url | stylesheet_tag }}
                      {% assign emptyState = true %}
                    {% endunless %}

                    {% include 'onboarding-grid-products' %}

                  {% endfor %}
                {% else %}
                   {% for product in collection.products %}
                      {% include 'product-grid-item4' %}
                    {% else %}
                      {% comment %}
                        For onboarding new users to your theme, we add some default products and onboarding tutorials to help populate their store
                      {% endcomment %}
                      {% unless emptyState %}
                        {{ 'theme-onboarding.css' | global_asset_url | stylesheet_tag }}
                        {% assign emptyState = true %}
                      {% endunless %}

                      {% include 'onboarding-grid-products' %}

                    {% endfor %}
                {% endif %}
             </div>
           </div>
        </section>
      {% endif %}

      {% if settings.grid_list_full == 'list' %}
        <section class="product-list">
            <div class="container-fluid">
              <div class="row">
                  <div class="inpage-title text-center">
                      {% if collection.description != blank %}
                        <h1>{{ collection.title }}</h1>
                        <p>{{ collection.description }}</p>
                      {% else %}
                        <h1>{{ collection.title }}</h1>
                      {% endif %}
                  </div>
              </div>
              {% for product in collection.products %}
                {% include 'product-list-item' %}
              {% else %}
                {% comment %}
                  For onboarding new users to your theme, we add some default products and onboarding tutorials to help populate their store
                {% endcomment %}
                {% unless emptyState %}
                  {{ 'theme-onboarding.css' | global_asset_url | stylesheet_tag }}
                  {% assign emptyState = true %}
                {% endunless %}

                {% include 'onboarding-list-products' %}

              {% endfor %}
            </div>
        </section>
      {% endif %}

      {% if settings.grid_list_full == 'full' %}
        <section class="product-full-width">
            <div class="container-fluid">
              <div class="row">
                  <div class="inpage-title text-center">
                      {% if collection.description != blank %}
                        <h1>{{ collection.title }}</h1>
                        <p>{{ collection.description }}</p>
                      {% else %}
                        <h1>{{ collection.title }}</h1>
                      {% endif %}
                  </div>
              </div>
              {% for product in collection.products %}
                {% include 'product-full-item' %}
              {% else %}
                {% comment %}
                  For onboarding new users to your theme, we add some default products and onboarding tutorials to help populate their store
                {% endcomment %}
                {% unless emptyState %}
                  {{ 'theme-onboarding.css' | global_asset_url | stylesheet_tag }}
                  {% assign emptyState = true %}
                {% endunless %}

                {% include 'onboarding-full-products' %}

              {% endfor %}
            </div>
        </section>
      {% endif %}
 	  {% include 'pagination2' %}
    </div>
  </div>
</div>
{% else %}

  {% if settings.grid_list_full == 'grid' %}
    <section class="products-grid">
      <div class="container">
        <div class="row">
          <div class="col-md-12">
            <div class="section-title">
              <div class="title-sep-container title-sep-container-left">
                <div class="title-sep"></div>
              </div>
              <h2 class="page-title h1-size text-center">{{ collection.title }}</h2>
              <div class="title-sep-container title-sep-container-right">
                <div class="title-sep"></div>
              </div>
            </div>
            <p class="section-subtitle">{{ collection.description | truncate: 100}}</p>
          </div>
        </div>
        <div class="row products-container">
            {% if settings.grid_type == 'overlay' %}
                {% for product in collection.products %}
                    {% include 'product-grid-item' %}
                {% else %}
                  {% comment %}
                    For onboarding new users to your theme, we add some default products and onboarding tutorials to help populate their store
                  {% endcomment %}
                  {% unless emptyState %}
                    {{ 'theme-onboarding.css' | global_asset_url | stylesheet_tag }}
                    {% assign emptyState = true %}
                  {% endunless %}

                  {% include 'onboarding-grid-products' %}

                {% endfor %}
              {% else %}
            	{% for product in collection.products %}
                    {% include 'product-grid-item3' %}
                {% else %}
                  {% comment %}
                    For onboarding new users to your theme, we add some default products and onboarding tutorials to help populate their store
                  {% endcomment %}
                  {% unless emptyState %}
                    {{ 'theme-onboarding.css' | global_asset_url | stylesheet_tag }}
                    {% assign emptyState = true %}
                  {% endunless %}

                  {% include 'onboarding-grid-products' %}

                {% endfor %}
              {% endif %}
         </div>
       </div>
    </section>
  {% endif %}

  {% if settings.grid_list_full == 'list' %}
    <section class="product-list">
        <div class="container">
          <div class="row">
              <div class="inpage-title text-center">
                  {% if collection.description != blank %}
                    <h1>{{ collection.title }}</h1>
                    <p>{{ collection.description }}</p>
                  {% else %}
                    <h1>{{ collection.title }}</h1>
                  {% endif %}
              </div>
          </div>
          {% for product in collection.products %}
            {% include 'product-list-item' %}
          {% else %}
            {% comment %}
              For onboarding new users to your theme, we add some default products and onboarding tutorials to help populate their store
            {% endcomment %}
            {% unless emptyState %}
              {{ 'theme-onboarding.css' | global_asset_url | stylesheet_tag }}
              {% assign emptyState = true %}
            {% endunless %}

            {% include 'onboarding-list-products' %}

          {% endfor %}
        </div>
    </section>
  {% endif %}

  {% if settings.grid_list_full == 'full' %}
    <section class="product-full-width">
        <div class="container">
          <div class="row">
              <div class="inpage-title text-center">
                  {% if collection.description != blank %}
                    <h1>{{ collection.title }}</h1>
                    <p>{{ collection.description }}</p>
                  {% else %}
                    <h1>{{ collection.title }}</h1>
                  {% endif %}
              </div>
          </div>
          {% for product in collection.products %}
            {% include 'product-full-item' %}
          {% else %}
            {% comment %}
              For onboarding new users to your theme, we add some default products and onboarding tutorials to help populate their store
            {% endcomment %}
            {% unless emptyState %}
              {{ 'theme-onboarding.css' | global_asset_url | stylesheet_tag }}
              {% assign emptyState = true %}
            {% endunless %}

            {% include 'onboarding-full-products' %}

          {% endfor %}
        </div>
    </section>
  {% endif %}

  {% include 'pagination' %}
{% endif %}


{% endpaginate %}

{{ 'option_selection.js' | shopify_asset_url | script_tag }}