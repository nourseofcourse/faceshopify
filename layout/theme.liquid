<!doctype html>
<!--[if IE 8]><html class="no-js lt-ie9" lang="en"> <![endif]-->
<!--[if IE 9 ]><html class="ie9 no-js"> <![endif]-->
<!--[if (gt IE 9)|!(IE)]><!--> <html class="no-js"> <!--<![endif]-->
<head>

  <!-- Basic page needs ================================================== -->
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">

  {% if settings.favicon_enable %}
    <link rel="shortcut icon" href="{{ 'favicon.png' | asset_url }}" type="image/png" />
  {% endif %}

  <!-- Title and description ================================================== -->
  <title>
    {{ page_title }}{% if current_tags %}{% assign meta_tags = current_tags | join: ', ' %} &ndash; {{ 'general.meta.tags' | t: tags: meta_tags }}{% endif %}{% if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif %}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}
  
  {% if product.url %}
    <!-- Product Social meta ================================================== -->
    <meta property="og:title" content="{{ product.title | escape }}" />
    <meta property="og:url" content="{{ shop.url }}{{ product.url }}" />
    <meta property="og:description" content="{{ product.description | strip_html }}" />
    <meta property="og:image" content="{{ product.featured_image.src | img_url: 'master' }}" />
  
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ product.title | escape }}">
    <meta name="twitter:description" content="{{ product.description | strip_html }}">
    <meta name="twitter:image" content="{{ product.featured_image.src | img_url: 'master' }}">
  {% endif %}

  <!-- Helpers ================================================== -->
  
  <link rel="canonical" href="{{ canonical_url }}">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="theme-color" content="{{ settings.color_primary }}">
  
  <!-- Fonts ================================================== -->
  <link href='//fonts.googleapis.com/css?family={{ settings.heading_font }}:400,700,600,500,300' rel='stylesheet' type='text/css'>
  <link href='//fonts.googleapis.com/css?family={{ settings.body_font }}:400,700,600,500,300' rel='stylesheet' type='text/css'>
  <link href="https://fonts.googleapis.com/css?family=Montserrat" rel="stylesheet">

  <link rel="stylesheet" href="//maxcdn.bootstrapcdn.com/font-awesome/4.4.0/css/font-awesome.min.css">

  <!-- CSS ================================================== -->
  {{ 'bootstrap.css' | asset_url | stylesheet_tag }}
  {{ 'magnific.css' | asset_url | stylesheet_tag }}
  {{ 'style.scss.css' | asset_url | stylesheet_tag }}
  {{ 'color.scss.css' | asset_url | stylesheet_tag }}

  <!-- Header hook for plugins ================================================== -->
  {{ content_for_header }}
  
  {{ '//ajax.googleapis.com/ajax/libs/jquery/1.11.0/jquery.min.js' | script_tag }}
  {{ 'modernizr.min.js' | asset_url | script_tag }}
  {{ 'jquery.js' | asset_url | script_tag }}
  
  <!--[if lt IE 9]>
  {{ 'html5shiv.min.js' | asset_url | script_tag }}
  {{ 'respond.min.js' | asset_url | script_tag }}
  <![endif]-->
  
  {% comment %}
    If you store has customer accounts disabled, you can remove the following JS file
  {% endcomment %}
  {% if template contains 'customers' %}
    {{ 'shopify_common.js' | shopify_asset_url | script_tag }}
  {% endif %}

</head>

<body id="{{ page_title | handle }}" class="{% if customer %}customer-logged-in {% endif %}template-{{ template | replace: '.', ' ' | truncatewords: 1, '' | handle }}" >

  {% include 'side-cart' %}
  {% include 'navigation-fixed' %}
  <div id="direction-waypoint"></div>
  <div class="main-container">
    {{content_for_layout}}
  </div>

  {% include 'newsletter' %}
  {% include 'instagram' %}
  {% include 'footer' %}
  
  {% comment %}
    Theme Scripts
  {% endcomment %}
  
  {{ 'handlebars.min.js' | asset_url | script_tag }}
  {% include 'ajax-cart-template' %}
  {{ 'ajax-cart.js' | asset_url | script_tag }}
  {{ 'option_selection.js' | shopify_asset_url | script_tag }}
  
  {% include 'general-scripts' %}
  
  {{ 'bootstrap.min.js' | asset_url | script_tag }}
  {{ 'imagesloaded.min.js' | asset_url | script_tag }}
  {{ 'isotope.min.js' | asset_url | script_tag }}
  {{ 'stellar.min.js' | asset_url | script_tag }}
  {{ 'sidr.min.js' | asset_url | script_tag }}
  {{ 'popup.min.js' | asset_url | script_tag }}
  {{ 'slick.min.js' | asset_url | script_tag }}
  {{ 'jquery.ajaxchimp.js' | asset_url | script_tag }}
  {{ 'instafeed.min.js' | asset_url | script_tag }}
  {{ 'simplyscroll.js' | asset_url | script_tag }}
  {{ 'matchheight.js' | asset_url | script_tag }}
  {{ 'magnific.min.js' | asset_url | script_tag }}
  {{ 'scripts.js' | asset_url | script_tag }}
  <script>
  window.intercomSettings = {
    app_id: "temb1b6r"
  };
</script>
