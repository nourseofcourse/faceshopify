<script>
  !function() {
    $('[data-plugin="scrollTo"]').on('click touch', function() {
      var href= $(this).attr('href'),
		  navbar = $('.navbar-default');

      $("html, body").animate({ scrollTop: $(href).offset().top - 100 }, 1000);
    });

    if( /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) ) {

      $('.bf-image').on('click touch', function() {
        var img = $(this).find('img');
        var hover = img.attr('data-hover');
        var original = img.attr('src');
        img.fadeOut(100, function() {
          img.attr('src', hover).attr('data-hover', original).fadeIn(500);
        });
      });
    }
    $('.bf-image').hover(function() {
      var img = $(this).find('img');
      var hover = img.attr('data-hover');
      var original = img.attr('src');
      img.fadeOut(190, function() {
          img.attr('src', hover).attr('data-hover', original).fadeIn(500);
        });
    }, function() {
      var img = $(this).find('img');
      var hover = img.attr('data-hover');
      var original = img.attr('src');
      img.fadeOut(100, function() {
          img.attr('src', hover).attr('data-hover', original).fadeIn(500);
        });
    });

    $('.js-play-btn').magnificPopup({

		type: 'iframe',
		mainClass: 'mfp-fade',
		removalDelay: 160,
		preloader: false,

		fixedContentPos: false
	});
  }();
</script>
