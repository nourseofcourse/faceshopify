// _color.scss


//You can edit this by customizing your theme
$primary-color: {{ settings.main_color }};

$link-color: {{ settings.link_color}};
$link-hover-color: {{ settings.link_color_hover}};

$footer-bg-color: {{ settings.footer_bg_color }};

$default-buttons-background: {{ settings.default_buttons_background }};
$default-buttons-color: {{ settings.default_buttons_color }};

$primary-buttons-border: {{ settings.primary_buttons_border }};
$primary-buttons-color: {{ settings.primary_buttons_color }};


$slider_default-buttons-background: {{ settings.slider_default_buttons_background }};
$slider_default-buttons-color: {{ settings.slider_default_buttons_color }};

$slider_primary-buttons-border: {{ settings.slider_primary_buttons_border }};
$slider_primary-buttons-color: {{ settings.slider_primary_buttons_color }};

.hero-slider {
  .btn-default {
  	background: $slider_default-buttons-background!important;
    color: $slider_default-buttons-color!important;
  }
  
  .btn-primary {
  	border-color: $slider_primary-buttons-border!important;
    color: $slider_primary-buttons-color!important;
  }
}

.notify.sale {
	background: $primary-color;
}


p a,
.accent-color{
  color: $primary-color;
}

a {
	color: $link-color;
	
	&:hover,
	&:focus {
		color: $link-hover-color;
		text-decoration: none;
		opacity:.7;
	}
}

.navbar-default {
	.navbar-nav {
		li {
			a {
				&:hover,
				&:focus {
					color: $primary-color;
					opacity: .8;
				}
			}

			a.menu-cart {
				color: $primary-color;

				&:hover,
				&:focus {
					color: $primary-color;
					opacity: .8;
				}
			}
		}

		.active {
			a {
				color: $primary-color;
				
				&:hover,
				&:focus {
					background: none;
					color: $primary-color;
					opacity: .8;
				}
			}
		}
	}

	.navbar-toggle {
		&:hover,
		&:focus {
			.icon-bar {
				background: $primary-color;
			}
		}
	}

	@media screen and (max-width: 768px) {
		background: #F5F5F7;
	}
}

.navbar {
	.open {
		a {
			color: $primary-color;
			&:hover,
			&:focus,
			&:active {
				color: $primary-color!important;
			}
		}
	}
}

.accent-bg {
	background-color: $primary-color;
}

.btn-default,
input[type="submit"],
input[type="button"],
input[type="reset"] {
	background-color: $default-buttons-background;
  	color: $default-buttons-color;
	
	&:hover,
	&:focus, 
	&:active,
	&:active:hover,
	&:active:visited {
		background-color: $default-buttons-background;
		opacity: .8;
		color: $default-buttons-color;
	}
}

.btn-default,
input[type="submit"],
input[type="button"],
input[type="reset"] {
	color: $default-buttons-color;
	&:hover,
	&:focus,
	&:active,
	&:active:hover,
	&:active:visited {
		color: $default-buttons-color;
		box-shadow: none;
	}
}

.btn.btn-primary {
	background: none;
	color: $primary-buttons-color;
	border-color: $primary-buttons-border;
	&:hover,
	&:focus,
	&:active,
	&:active:hover,
	&:active:visited {
		opacity: .8;
		background-color: transparent;
		border-color:  $primary-buttons-border;
		color: $primary-buttons-color;
		box-shadow: none;
	}
}

.action-bar {
	a {
		&:hover,
		&:focus {
			background-color: $primary-color;
			color: #fff;

			span {
				color: #fff;
			}
		}
	}
}

.overlay.accent {

	&:before {
		position: absolute;
	    width: 100%;
	    height: 100%;
	    top: 0px;
	    content: '';
	    opacity: 0.9;
	    z-index: 2;
		background-color: $primary-color;
	}

}

.accent-bg {
	color: #fff;

	p, h2 {
		color: #fff;
	}

	.btn.btn-primary {
		border-color: #fff;
		color: #fff;
	}

	.btn.btn-default {
		background: #fff;
		color: $primary-color;
	}
}

section.products-grid {
    .product {

        .product-details {
        	&:before {
        		background: $primary-color;
        	}
        }
    }
}

.thumbnail.with-info {

	.info {
		background: $primary-color;
	}
}

a {
	&:hover,
	&:focus {
		.custom-icon {
			span {
				border-color: $primary-color!important;
			}
		}
	}
}

.map-wrapper {
	.directions {
		background-color: $primary-color;
		color: #fff;

		&:hover,
		&:focus {
			opacity: .8;
		}
	}
}

.product-full-width {
	.product {
		.thumbnail {
			.product-details {
				background: $primary-color;
			}
		}
	}
}

.product-list {
	.product {
      a {
        &:hover,
        &:focus {
            color: $primary-color!important;
        }
      }
      
      .product-price {
      	color: $primary-color;
      }
    }
}

.product-single {
  .product-price {
    color: $primary-color;
  }
}

.error {
	h1 {
		color: $primary-color;
	}
}

#comments {
	.notice {
      	color: $primary-color;
    }
}

#ResetSuccess {
	color: $primary-color;
}

.thumbnail.with-info {
  .info-on-sale {
      background: $primary-color;
  }
  
  .info-sold-out {
  	background: #bcbcbc;
  }
}

#delivery-date .ui-datepicker .ui-state-default.ui-state-active {
	background: $primary-color!important;
  	color: #fff;
}

.errors {
  ul {
    li {
    	list-style: none;
      	color: $primary-color;
    }
  }
}

.ui-datepicker .ui-state-default:hover {
	background: $primary-color!important;
  	color: #fff;
}

#product-tabs {
  .nav-tabs {
    li {
      a {
        &:before {
          background-color: $primary-color!important;
        }
      }
    }
    
    .ui-state-active {
      a {
      	&:before {
          width: 100%;
        }
      }
    }
  }
}

.spr-summary {
  color: $primary-color!important;
}

footer.footer {
	background: $footer-bg-color;
}