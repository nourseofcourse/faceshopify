/* replaceUrlParam - http://stackoverflow.com/questions/7171099/how-to-replace-url-parameter-with-javascript-jquery */
function replaceUrlParam(e,r,a){var n=new RegExp("("+r+"=).*?(&|$)"),c=e;return c=e.search(n)>=0?e.replace(n,"$1"+a+"$2"):c+(c.indexOf("?")>0?"&":"?")+r+"="+a};


$(document).ready(function() {
	
	"use strict";
	

    $('.main-container section:first-child').addClass('first-child');

    $.stellar({
        horizontalScrolling: false,
        verticalScrolling: true,
        horizontalOffset: 0,
        verticalOffset: 0,
        responsive: true,
        parallaxBackgrounds: true
    });

    $('.fullHeight').each(function(){
		$(this).css('height', $(window).height()-125);
	});

    alignVertical();
   	halfMarginTop();
	
	$(window).resize(function(){
		alignVertical();
		halfMarginTop();
	});

  
  	//Set a class for each full product
  	
    if ($('.product-full-width').length) {
      var count = 0;
      $('.product-full-width .product').each(function(){
        var caption = $(this).find('.product-details');
      	count++;
        if (count%2 == 0) {
        	caption.addClass('right');
        } else {
            caption.addClass('left');
        }
      });
    }
 
  
  	{% if settings.sticky_nav %}
      //Sticky navbar
      $(window).scroll(function(){
        if ($(window).scrollTop() > 300) {
            $('.navbar-default').addClass('sticky');
        } else {
            $('.navbar-default').removeClass('sticky');
        }
      });
  	{% endif %}
	
	//Products Grid

	if ($('.products-container').length) {
		$('.products-grid').imagesLoaded( function() {
          $('.products-container').isotope({
            itemSelector: '.product',
            layoutMode: 'fitRows'
          });
        });
	}

	
	//Offscreen cart
  	// Load Ajax cart on open

	if ($('.side-menu-opener').length) {
		$('.side-menu-opener').sidr({
			side: 'right',
			onOpen: ajaxCart.load,
            displace: true,
		    onClose: function() {
		    	//Do something on CLOSE
		    }
		});
	}
  
  	$('.side-menu-closer').on('click', function() {
