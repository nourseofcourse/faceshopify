     });

	
	//Hero Slider 

	if ($('.hero-slider').length ) {
      	$('.hero-slider').on('init', function(slick) {
          	$('.hero-loader').fadeOut(1000);
        });
      
    	$('.hero-slider').slick({
    		dots: true,
    		fade: true,
			autoplay: true,
  			autoplaySpeed: 4000,
			pauseOnHover: true
    	});
    }


	//Team Carousel

	if ($('.team-carousel').length ) {

		$('.team-carousel').slick({
		  	centerMode: !0,
	        dots: !0,
	        arrows: !1,
	        accessibility: !0,
	        infinite: !0,
	        speed: 650,
	        centerPadding: "500px",
	        cssEase: "ease",
	        slidesToShow: 1,
	        draggable: !0,
	        responsive: [{
	            breakpoint: 1600,
	            settings: {
	                centerPadding: "300px"
	            }
	        }, {
	            breakpoint: 1200,
	            settings: {
	                centerPadding: "125px"
	            }
	        }, {
	            breakpoint: 991,
	            settings: {
	                centerPadding: "125px"
	            }
	        }, {
	            breakpoint: 768,
	            settings: {
	                centerPadding: "27px"
	            }
	        }]
		});

		// Show the active item on document ready
		$('.team-carousel .slick-current .member-info').css('opacity', '1');

		// On before slide change
		$('.team-carousel').on('beforeChange', function(event, slick, currentSlide, nextSlide){
			$('.slick-current .member-info').css('opacity', '0');
		});

		// On after slide change
		$('.team-carousel').on('afterChange', function(event, slick, currentSlide){
			$('.slick-current .member-info').css('opacity', '1');
		});
	}


	//Load more button

	if ($('.load-more').length ) {
		$('.load-more').click(function(e) {
			e.preventDefault();
			$(this).find('i').removeClass('fa-ellipsis-h').addClass('fa-circle-o-notch fa-spin fa-fw');
			return false;
		});
	}
 

	// Google maps

	if ($('#map').length) {
		google.maps.event.addDomListener(window, 'load', initialize_map('#map'));
	}

    if ($('a.lightbox').length) {
	    $('a.lightbox').each(function() {
	    	$(this).magnificPopup({
	    		type: 'image'
	    	});
	    });
	}
  
  	//Change view
  	
  	if ($('.change-view').length) {
      $('.change-view').on('click', function() {
        var view = $(this).data('view'),
            url = document.URL,
            hasParams = url.indexOf('?') > -1;

        if (hasParams) {
          window.location = replaceUrlParam(url, 'view', view);
        } else {
          window.location = url + '?view=' + view;
        }
        return false;
      });
    }
  
  	
  	//Account pages
  	
      function showRecoverPasswordForm() {
        $('#RecoverPasswordForm').show();
        $('#CustomerLoginForm').hide();
      }

      function hideRecoverPasswordForm() {
        $('#RecoverPasswordForm').hide();
        $('#CustomerLoginForm').show();
      }

      $('#RecoverPassword').on('click', function(evt) {
        evt.preventDefault();
        showRecoverPasswordForm();
      });

      $('#HideRecoverPasswordLink').on('click', function(evt) {
        evt.preventDefault();
        hideRecoverPasswordForm();
      });
  
  
  	//Instafeed
    var feed = new Instafeed({
        get: "user",
        userId: {{ settings.instagram_id }},
        limit: 50,
        accessToken: "{{ settings.instagram_access_token }}",
        resolution: "thumbnail",
        after: function() {
            $("#instafeed").simplyScroll({
                speed: {{ settings.instagram_speed }},
                frameRate: 25,
              	auto: false,
                orientation: "horizontal",
                direction: "forwards",
                customClass: "instagram_scroller"
            });
        }
    });
    feed.run();
 
  
});


function alignVertical() {

	$('.align-vertical').each(function(){
		var that = $(this);
			height = that.height(),
			parentHeight = that.parent().height(),
			padAmount = (parentHeight / 2) - (height/2);
		if (that.hasClass('hero')) {
			that.css('padding-top', padAmount+20);
		} else {
			that.css('padding-top', padAmount);
		}
	});
	
}

function halfMarginTop() {

	$('.half-margin-top').each(function(){
		var that = $(this);
			height = that.height()/2+40,
		
		that.css('margin-top', -height);
	});
	
}

