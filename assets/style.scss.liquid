// _sections.scss
.fullscreen-element {
	position: relative;
}
.hero-loader {
    background: #fff;
    width: 100%;
    height: 100%;
    display: block;
    position: absolute;
    z-index: 99;
  img {
  	position: absolute;
    left: 50%;
    top: 50%;
    margin-left: -16px;
    margin-top: -16px;
  }
}
.hero-slider {
    height: 100%;
  	position: relative;
    display: block;

    .slide, .slick-list, .slick-track {
        height: 100%;
    }

    .slide {
        background-repeat: no-repeat!important;
        background-color: #F5F5F7!important;
        background-size: cover!important;

        &:focus {
            outline: none;
        }
    }

    .slick-dots {
        bottom: 25px;
    }
}

.action-bar {
    padding-top: 0px;
    padding-bottom: 0px;
    text-align: center;
    border-bottom: 1px solid #f1f1f1;
  	border-top: 1px solid #f1f1f1;

    .col-md-4, .col-sm-4 {
        padding:0;
        margin: 0;

        &:last-child {
            @media screen and (min-width: 768px) {
                border-right: 1px solid #f1f1f1;
            }
        }
    }

    a {
        padding-top: 20px;
        padding-bottom: 20px;
        width: 100%;
        display: block;
        position: relative;
        line-height: 55px;
        text-align: center;

        i {
            font-size: 28px;
            color: #323237;
        }

        &:hover,
        &:focus {
            text-decoration: none;
            opacity: 1;

            i {
                color: #fff;
            }

        }

        @media screen and (min-width: 768px) {
            border-left: 1px solid #f1f1f1;
        }

        @media screen and (max-width: 768px) {
            border-bottom: 1px solid #f1f1f1;
        }

        span.icon {
            position: relative;
            top: 13px;
            left: -9px;
            margin-top: -6px;
            display: none;
        }

        span.text {
            color: #323237;
        }
    }

    .icon {
        font-size: 42px;
    }

    @media screen and (max-width: 768px) {
        border: none;
    }
}

.featured-collections {
	padding: 80px 0px;

  h3 {
  	margin-bottom: 0;
    margin-top: 30px;
    text-transform: uppercase;

    a {
    	color: #333;
      	position: relative;
      	padding-bottom: 20px;

      &:after {
      	content: '';
        height: 1px;
        width: 100%;
        background: #f1f1f1;
        position: absolute;
        left: 0;
        bottom: 0px;
      }
    }
  }
}

.continue-shopping {
  margin-top: 20px;
  cursor: pointer;

  &:hover {
  	opacity: .7;
  }
}

section.newsletter {
    padding-top: 50px;
    padding-bottom: 50px;

    input, a {
        margin-top: 40px;
    }

  .overlay.accent {
    &:before {
      background-color: {{ settings.newsletter_background }};
    }
  }

    input {
        font-size: 16px;
        padding-left: 25px;
        border-radius: 30px;
        border: none;
        margin-bottom: 0;
        height: 43px;
        color: #8D8D8D;
    }

    #fc-response {
      font-size: 13px;
      padding-left: 20px;
      padding-top: 4px;
    }

    h2.page-title {
        margin-bottom: 10px;
    }

    @media screen and (max-width: 991px) {
        input {
            margin-top: 30px;
        }

        a {
            margin-top: 30px;
        }

        .row {
            text-align: center;
        }

        h2 {
            margin-top: 20px;
        }

        .text-left {
            text-align: center;
        }
    }

    .newsletter-form {
      @media screen and (max-width: 992px) {
        input.btn {
          margin: 30px auto!important;
        }
      }
    }
}

section.products-grid {
    padding-bottom: 90px;

    .product {
        position: relative;
        overflow: hidden;
        height: 300px;
        margin-bottom: 30px;

        &:hover {
            .product-details {
                opacity: 1;
            }
        }


        .thumbnail {
            height: 300px;
            background-repeat: no-repeat;
            background-position: 50% 50%;
            background-size: cover;
        }

        .thumbnail.with-info {
          .info {
            top: 20px;
            left: 20px;

          }
        }

        .product-details {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            opacity: 0;
            -webkit-transition: all 500ms ease;
            -moz-transition: all 500ms ease;
            transition: all 500ms ease;



            &:before {
                content: '';
                position: absolute;
                left: 0;
                top: 0;
                width: 100%;
                height: 100%;
                z-index: -1;
                opacity: .9;
            }

            h3 {
                color: #fff;
                font-weight: bold;

                a {
                  color: #fff;
                }
            }

            a.btn,
            button.btn {
                color: #fff;
                border-color: #fff;
                margin-bottom: 20px;

                &:hover,
                &:focus {
                    opacity: .8;
                }
            }
        }

        .product-price {
            color: #fff;
            font-weight: bold;
        }

        @media screen and (max-width: 768px) {
            margin-bottom: 15px;
        }
    }

  .product {
    .thumbnail.with-info {
      .info {
        display: block;
      }
    }
  }
}

.product.type-3 {
	height: auto!important;
}

.product.type-3 {
  .image {
      position: relative;
  }

  h2 {
      margin-bottom: 10px;
      margin-top: 20px;
      font-size: 24px;
      line-height: 34px;

    a {
    	color: #333;
    }
  }

  .rating {
      margin-bottom: 15px;
      margin-bottom: 10px;
  }

  .spr-badge-caption {
    display: none;
  }

  .price {
  	font-weight: 900;
    font-size: 12px;
    line-height: 2rem;
    margin-bottom: 1.1857rem;
    padding-top: 0px;
    position: relative;
    color: #b7c2ca;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
}

.product.type-3 .description .rating {
    margin-top: 30px;
    font-size: 14px;
    letter-spacing: 1px;
}

.notify {
    width: 65px;
    height: 30px;
    line-height: 30px;
    text-align: center;
    position: absolute;
    right: 0;
    top: 0;
    background: #b7c2ca;
    color: #fff;
