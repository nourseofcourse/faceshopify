 * 9. Blog
 * 10. Contact
 * 11. Bootstrap Theme
 * 12. Buttons
 * 13. Slick Carousel
 * 14. Slick Carousel Theme
 * 15. Colors
 * 16. Lightbox */
/* GENERAL STYLES */

a,
button span {
  -webkit-transition: all .5s ease;
  -moz-transition: all .5s ease;
  transition: all .5s ease;
}

section,
.section {
  padding-top: 100px;
  padding-bottom: 100px;
  position: relative;
  overflow: hidden;
}

section.featured-section {
  padding-top: 120px;
  padding-bottom: 120px;

  h2 {
  	font-size: 42px;
    line-height: 54px;
  }
}

.section-title {
    display: -webkit-flex;
    display: -ms-flexbox;
    display: flex;
    -webkit-flex-wrap: nowrap;
    -ms-flex-wrap: nowrap;
    flex-wrap: nowrap;
    -webkit-align-items: center;
    -ms-align-items: center;
    -ms-flex-align: center;
    align-items: center;
    margin: 0 0 10px;
    overflow: hidden;

  .title-sep-container {
    position: relative;
    height: 6px;
    -webkit-flex-grow: 1;
    -ms-flex-grow: 1;
    -ms-flex-positive: 1;
    flex-grow: 1;

    .title-sep {
      	border-bottom: 1px solid #F1F1F1;
    }
  }

  h2 {
  	-webkit-flex-grow: 0;
    -ms-flex-grow: 0;
    -ms-flex-positive: 0;
    flex-grow: 0;
    margin: 0!important;
    line-height: 48px;
    padding: 0 45px;
  }
}

.section-subtitle {
	text-align: center;
  	margin-bottom: 70px!important;
}

h2.h1-size {
	font-size: 42px!important;
    line-height: 54px!important;
}

section.no-padding-top,
.section.no-padding-top {
  padding-top: 0;
}

section.no-padding-bottom {
  padding-bottom: 0;
}

section.small-padding {
  padding: 40px 0px;
}

img {
  max-width: 100%;
}

input {
  width: 100%;
  border: none;
  border-radius: $border-radius;
  height: 43px;
}

header  {
  position: relative;
    overflow: hidden;
  .container {
      position: relative;
      z-index: 3;
  }

  p {
    margin-bottom: 10px;
  }
}

header.secondary {
  height: 450px;
}

header.secondary.small {
  height: 104px;

  .overlay {
    top: 0%;
  }
}

.background-image-holder,
.parallax {
    position: absolute;
    top: 0px;
    left: 0px;
    width: 100%;
    height: 100%;
    background-size: cover !important;
    z-index: 0;

    p {
      margin-bottom: 15px!important;
    }
}

.background-image-holder.on-page {
  background-position: 50% 50% !important;
}

.background-image-holder.overlay {
  &:before {
    @media screen and (max-width: 768px) {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0px;
        content: '';
        opacity: 0.7;
        z-index: 2;
        background-color: #fff;
    }
  }
}

.background-image-holder.parallax-background {
    height: 100%;
}

.main-container {
    -webkit-transition: all .3s ease;
    -moz-transition: all .3s ease;
    transition: all .3s ease;
    -webkit-transform: translate3d(0px, 0, 0);
    -moz-transform: translate3d(0px, 0, 0);
    transform: translate3d(0px, 0, 0);
    overflow: hidden;
    width: 100%;
}

.thumbnail {
  padding:0;
  border-radius: 0;
  border: none;
  margin: 0;
  position: relative;
}

.thumbnail.with-info {
  position: relative;
  margin-bottom: 90px;

  .info {
    position: absolute;
    left: 30px;
    bottom:-30px;
    width: 60px;
    height: 60px;
    text-align: center;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0;
    line-height: 15px;

    span {
      font-size: 18px;
      font-weight: bold;
      display: block;

      &:nth-child(2) {
        font-size: 11px;
      }
    }
  }
}

.error {
  h1 {
    font-size: 120px;
    line-height: 130px;
    font-weight: 900;
  }
}


// _typography.scss

body {
  font-family: $body-font-family;
  -webkit-font-smoothing: antialiased;
  color: $body-color;
  font-size: $body-font-size+px;
  line-height: $body-font-size+10+px;
  font-weight: 500;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

h1,
h2,
h3,
h4,
h5,
h5,
h6 {
  font-family: $heading-font-family;
  font-weight: 400;
  color: #323237;
  margin: 0px;
}

h1, h2.product-title {
  font-size: $heading1-font-size+px;
  line-height: $heading1-font-size+12+px;
  margin-bottom: 20px;
  color: $heading1-color;
}

h2.page-title {
  font-size: 32px;
  line-height: 44px;
  margin-bottom: 20px;
  color: $heading1-color;
}
h2 {
  font-size: $heading2-font-size+px;
  line-height: $heading2-font-size+12+px;
  color: $heading2-color;
}
h3 {
  font-size: $heading3-font-size+px;
  line-height: $heading3-font-size+12+px;
  color: $heading3-color;
  font-weight: 400;
  margin-bottom: 15px;
}
h4 {
  font-size: $heading4-font-size+px;
  line-height: $heading4-font-size+12+px;
  color: $heading4-color;
  font-weight: 500;
  margin-bottom: 20px;
}
h5 {
  font-size: $heading5-font-size+px;
  line-height: $heading5-font-size+12+px;
  color: $heading5-color;
  font-weight: 600;
  margin-bottom: 16px;
}
h6 {
  font-size: $heading6-font-size+px;
  line-height: $heading6-font-size+12+px;
  color: $heading6-color;
  font-weight: 600;
  margin-bottom: 16px;
}
strong {
  font-weight: 600;
}
p {
  color: $body-color;
  font-size: $body-font-size+px;
  line-height: $body-font-size+10+px;
  margin: 0px 0px 30px;
}
p.lead {
  font-size: 20px;
  line-height: 34px;
  font-weight: normal;
}
p.hint {
  font-size: 14px;
  line-height: 24px;
  font-style: italic;
}
p:last-child {
  margin-bottom: 0px;
}
p.subtitle {
  margin-bottom: 30px;
}

.inpage-title {
  margin-bottom: 80px;
}

p.description {
  margin-bottom: 10px;
}

p.strong {
  font-weight: 700;
}

p {
  strong {
    color: #323237;
  }
}

// _forms.scss

input[type="text"],
input[type="email"],
input[type="month"],
input[type="date"],
input[type="datetime"],
input[type="datetime-local"],
input[type="number"],
input[type="file"],
input[type="password"],
input[type="time"],
input[type="week"],
input[type="url"],
input[type="tel"],
input[type="search"],
textarea {
  border: 2px solid #f2f3f5;
  border-radius: 0;
  margin-bottom: 40px;
  padding-left: 15px;
  padding-right: 15px;
  font-size: 16px;
  -webkit-transition: all .5s ease;
  -moz-transition: all .5s ease;
  transition: all .5s ease;

  &:focus {
    outline: none;
    border-color: #DCDCDC;
  }
}

textarea {
  resize: none;
}

input[type="color"] {
  border: 2px solid #f2f3f5;
  border-radius: 0;
  margin-bottom: 30px;
  font-size: 16px;
  background: none;
  -webkit-transition: all .5s ease;
  -moz-transition: all .5s ease;
  transition: all .5s ease;

  &:focus {
    outline: none;
    border-color: #DCDCDC;
  }
}

input[type="image"] {
  border: none;
  border-radius: 0;
  margin-bottom: 30px;
  font-size: 16px;
  background: none;
  -webkit-transition: all .5s ease;
  -moz-transition: all .5s ease;
  transition: all .5s ease;
    width: auto;
    display: block;
    margin: 20px auto;

  &:focus {
    outline: none;
    border-color: #DCDCDC;
  }
}

.additional_checkout_buttons {
  input[type="image"] {
    background: #fff;
    border-radius: 3px;
    padding-top: 5px;
    padding-left: 3px;
    padding-right: 4px;
  }
}

input[type="text"],
input[type="email"] {
  height: 50px;
}

textarea {
  width: 100%;
  min-height: 150px;
  padding-top: 10px;
}

input[type="button"],
input[type="submit"],
input[type="reset"] {
  max-width: 180px;
    display: block;
    font-weight: bold;
    text-transform: uppercase;
    font-size: 14px;
    -webkit-transition: all .5s ease;
  -moz-transition: all .5s ease;
  transition: all .5s ease;

    &:focus {
      outline: none;
    }
}

.contact-form {
  input[type="submit"] {
    float: right;
  }

  @media screen and (max-width: 768px) {
    margin-top: 40px;
  }
}

.table-wrap {
  margin-top: 20px;
  @media screen and (max-width: 420px) {
    overflow: auto;
  }
}

.form-control.filter {
    width: auto;
    border-radius: 0;
    box-shadow: none;
    border: 2px solid #f2f3f5;
    color: #8D8D8D;
    font-weight: bold;
  margin-bottom: 40px;
}

.filter-form {
  text-align: center;
    display: table;
    width: 100%;

  label {
    display: inline;
    margin-right: 20px;
  }

  select {
    display: inline;
  }
}

select.form-control {
  border-radius: 0;
    box-shadow: none;
    border: 2px solid #f2f3f5;
    color: #8D8D8D;
    font-weight: bold;
}

#comments {
  .comments-title {
    margin-bottom: 60px;
  }

  .notice {
  margin-bottom: 40px;
  }
}

#comment-list {
  padding: 0;

    li {
      list-style: none;
      margin-bottom: 50px;
    }

    .comment-details {
        float: left;
      margin-right: 30px;
        width: 145px;
        text-align: right;

        span {
      display: block;
        }

        .comment-author {
      color: #333;
        }

      .comment-date {
        font-size: 13px;
      }
    }

    .comment {
        padding-left: 175px;
    }
}

.comment-form {
  margin-top: 50px;

  input, textarea {
    margin-bottom: 20px;
  }

  h3 {
    margin-bottom: 30px;
  }

  label {
    font-weight: normal;
    margin-bottom: 10px;
  }
}

.ajaxcart {
  margin-bottom: 60px;
  p {
    margin-bottom: 0;
    font-size: 14px;
    line-height: 18px;
  }
  padding: 15px!important;

  .js-qty input, .ajaxcart__qty input {
      display: block;
      background: none;
      text-align: center;
      width: 100%;
      padding: 5px 25px;
      margin: 0;
      height: 30px;
      border-width: 1px;
      border-color: rgba(255,255,255,.1);

  }

  .ajaxcart__qty-adjust {
      color: #fff;
      background: none;
  }

  .js-qty__adjust, .ajaxcart__qty-adjust {
      cursor: pointer;
      position: absolute;
      display: block;
      top: 0;
      bottom: 0;
      border: 0 none;
      padding: 0 10px;
      background: none;
      text-align: center;
      overflow: hidden;
      -webkit-user-select: none;
      -moz-user-select: none;
      -ms-user-select: none;
      user-select: none;
  }

  .js-qty__adjust--minus, .ajaxcart__qty--minus {
      left: 0;
      border-right: 1px solid;
  }

  .ajaxcart__qty--minus {
      border-color: rgba(255,255,255,.1);
  }

  .js-qty, .ajaxcart__qty {
      position: relative;
      margin-bottom: 10px;
      max-width: 100px;
      min-width: 75px;
      overflow: visible;
  }

  .js-qty__adjust--plus, .ajaxcart__qty--plus {
      right: 0;
      border-left: 1px solid;
      border-color: rgba(255,255,255,.1);
  }

  .ajaxcart__product {
    p {
      margin-bottom: 10px;
    }
  }

  .cart__checkout {
      display: block;
      width: 100%;
  }

  .display-table-cell {
      display: table-cell;
      vertical-align: middle;
      float: none;
  }

  .col-xs-8 {
    padding-left: 0;
  }

  .one-half {
      width: 50%;
  }

  .ajaxcart__row {
      padding-bottom: 15px;
      margin-bottom: 25px;
      border-bottom: 1px solid rgba(255,255,255,.1);
  }

  .strong {
    font-weight: bolder;
  }

  .ajaxcart__footer {
    p {
      margin-bottom: 10px;
    }
  }

  #CartSpecialInstructions {
    background-color: transparent;
    border: 1px solid rgba(255,255,255,.1);
    font-size: 14px;
    line-height: 20px;
    min-height: 100px;
    margin-bottom: 10px;
  }

}

.js-qty {
  position: relative;
  margin-bottom: 1em;
  max-width: 100px;
  min-width: 75px;
  overflow: visible;

  @media screen and (max-width: 768px) {

  }

  input {
      display: block;
      background: none;
      text-align: center;
      width: 100%;
      padding: 5px 25px;
      margin: 0;
      height: 36px;
  }
}

.js-qty__adjust {
    cursor: pointer;
    position: absolute;
    display: block;
    top: 0;
    bottom: 0;
    border: 0 none;
    padding: 0 8px;
    background: none;
    text-align: center;
    overflow: hidden;
    -webkit-user-select: none;
    -moz-user-select: none;
    -ms-user-select: none;
    user-select: none;
}

.js-qty__adjust--minus {
    left: 0;
    border-right: 2px solid #F2F3F5;
}

.js-qty__adjust--plus {
    right: 0;
    border-left: 2px solid #F2F3F5;
}

.page-cart {

  .cart-row {
      margin-top: 35px;
      padding-top: 35px;
      border-top: 1px solid #ebebeb;
  }

  .cart-item-title {
    position: relative;
    padding-right: 40px;
  }

  .cart-item {
    @media screen and (min-width: 768px) {
      display: table;
      width: 100%;

      .col-sm-4, .col-sm-2, .col-sm-3, .col-sm-3 {
          display: table-cell;
          vertical-align: middle;
          float: none;
      }
    }

    .cart-item-title {
      @media screen and (min-width: 768px) {
        h4, p {
          margin-bottom: 0;
        }
      }
    }

  }

  .datepicker-height {
      min-height: 262px!important;
      margin-bottom: 0;

    @media screen and (max-width: 768px) {
      margin-bottom: 30px;
        margin-top: 30px;
    }
  }

  .cart-remove {
      position: absolute;
      top: 0;
      right: 0;
  }

  .action-row {
      padding-top: 65px;
  }

  .update-cart {
    margin-right: 20px;
  }

  p {
    margin-bottom: 30px;
  }

  h4.line-total {
    font-size: 24px;
  }

  .btn {
      padding: 10px 20px!important;
      max-width: 150px;
  }

  label {
      color: #333;
      margin-bottom: 15px;
  }

  .cart__subtotal {
    margin-left: 30px;
    color: #E74C3C;
    font-weight: 900;
  }
}

.empty-side-cart {
  padding: 15px;

  p {
    font-size: 14px;
  }
}

#sidr {
    display: none;
}
.sidr {
    display: none;
    position: absolute;
    position: fixed;
    top: 0;
    height: 100%;
    z-index: 999999;
    width: 300px;
    overflow-x: none;
    overflow-y: auto;
    font-size: 13px;
    background: #323237;
    color: #fff;
}
.sidr .sidr-inner {
    padding: 0 0 15px;
}
.sidr.right {
    left: auto;
    right: -300px;
}
.sidr.left {
    left: -300px;
    right: auto;
}
.sidr ul {
    display: block;
    margin: 0px;
    padding: 0;
    margin-top: 30px;
}
.sidr ul li {
    display: block;
    margin: 0;
    line-height: 45px;
    border: none;
}
.sidr ul li:hover,
