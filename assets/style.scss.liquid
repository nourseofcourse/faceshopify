@charset "UTF-8";

//Variables

$border-radius: 30px;
$heading-font-family: "{{ settings.heading_font | replace: '+', ' ' }}", "Helvetica Neue", Helvetica, Arial, sans-serif;
$body-font-family: "{{ settings.body_font | replace: '+', ' ' }}", "Helvetica Neue", Helvetica, Arial, sans-serif;

$body-font-size: {{ settings.body_font_size}};
$body-color: {{ settings.body_color}};

$heading1-font-size: {{ settings.h1_font_size}};
$heading1-color: {{ settings.h1_color}};

$heading2-font-size: {{ settings.h2_font_size}};
$heading2-color: {{ settings.h2_color}};

$heading3-font-size: {{ settings.h3_font_size}};
$heading3-color: {{ settings.h3_color}};

$heading4-font-size: {{ settings.h4_font_size}};
$heading4-color: {{ settings.h4_color}};

$heading5-font-size: {{ settings.h5_font_size}};
$heading5-color: {{ settings.h5_color}};

$heading6-font-size: {{ settings.h6_font_size}};
$heading6-color: {{ settings.h6_color}};


$slide_1_title_color: {{ settings.slide_1_title_color}};
$slide_2_title_color: {{ settings.slide_2_title_color}};
$slide_3_title_color: {{ settings.slide_3_title_color}};

$slide_1_description_color: {{ settings.slide_1_description_color}};
$slide_2_description_color: {{ settings.slide_2_description_color}};
$slide_3_description_color: {{ settings.slide_3_description_color}};

$featured1_title_color: {{ settings.featured1_title_color}};
$featured1_description_color: {{ settings.featured1_description_color}};
$featured1_btn_border_color: {{ settings.featured1_btn_border_color }};
$featured1_btn_text_color: {{ settings.featured1_btn_text_color }};

$featured2_title_color: {{ settings.featured2_title_color}};
$featured2_description_color: {{ settings.featured2_description_color}};
$featured2_btn_border_color: {{ settings.featured2_btn_border_color }};
$featured2_btn_text_color: {{ settings.featured2_btn_text_color }};

$navigation-background: {{ settings.navigation_background }};

$slider_dots_color: #B0B0B0;

//Buttons
$border-radius: 30px;
$btn-padding: 12px 35px;
$btn-primary-padding: 10px 35px;
$btn-padding-mobile: 12px 20px;
$btn-primary-padding-mobile: 10px 20px;

//Slick Slider
$slick-font-path: "" !default;
$slick-font-family: "slick" !default;
$slick-loader-path: "ajax-loader.gif?8853115690660859706" !default;
$slick-arrow-color: white !default;
$slick-dot-color: black !default;
$slick-dot-color-active: $slick-dot-color !default;
$slick-prev-character: "←" !default;
$slick-next-character: "→" !default;
$slick-dot-character: "•" !default;
$slick-dot-size: 6px !default;
$slick-opacity-default: 0.75 !default;
$slick-opacity-on-hover: 1 !default;
$slick-opacity-not-active: 0.25 !default;

.error-page {
	height: 700px;
}

.hero-slider {
  .slide {

    h2 {
      text-shadow: 2px 5px 5px #000;
    }
    &:first-child {
      h2 {
      	color: $slide_1_title_color;
        font-size: 42px;
        line-height: 54px;
      }

      p {
      	color: $slide_1_description_color;
      }
    }

    &:nth-child(2) {
      h2 {
      	color: $slide_2_title_color;
        font-size: 42px;
        line-height: 54px;
      }

      p {
      	color: $slide_2_description_color;
      }
    }

    &:nth-child(3) {
      h2 {
      	color: $slide_3_title_color;
        font-size: 42px;
        line-height: 54px;
      }

      p {
      	color: $slide_3_description_color;
      }
    }
  }
}

.featured-section.featured1 {
  h2.page-title {
  	color: $featured1_title_color;
  }

  p {
  	color: $featured1_description_color;
  }

  .btn-primary {
  	color: $featured1_btn_text_color!important;
    border-color: $featured1_btn_border_color!important;
  }
}

.featured-section.featured2 {
  h2.page-title {
  	color: $featured2_title_color;
  }

  p {
  	color: $featured2_description_color;
  }

  .btn-primary {
  	color: $featured2_btn_text_color!important;
    border-color: $featured2_btn_border_color!important;
  }
}

#sidebar-categories {
  .last {
  	border-bottom: none;
  }

  .second-level {

    &:first-of-type {
    	border-top: 1px solid #f1f1f1;
      	margin-top: 10px;
    }
    a {
    	padding-left: 20px;
    }
  }

  .third-level {

    &:first-of-type {
    	border-top: 1px solid #f1f1f1;
      	margin-top: 10px;
    }
    a {
    	padding-left: 40px;
    }
  }

  .parent {
    h3 {
   	  font-size: 18px;
      font-weight: 500;
      line-height: 28px;
      margin-bottom: 0;
      position: relative;

      &:after {
        content: "\f067";
        font: normal normal normal 14px/1 FontAwesome;
        position: absolute;
        right: 0;
        top: 8px;
        color: #8d8d8d;
      }

      &:focus {
      	outline: none!important;
      }
    }

    .ui-accordion-header-active {
    	&:after {
          content: "\f068";
          font: normal normal normal 14px/1 FontAwesome;
          position: absolute;
          right: 0;
          top: 8px;
          color: #8d8d8d;
        }
    }
  }
}

