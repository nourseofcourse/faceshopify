$footer-link-color: {{ settings.footer_link_color }};
$footer-social-color: {{ settings.footer_social_color }};
$footer-borders-color: {{ settings.footer_borders_color }};
$footer-payment-color: {{ settings.footer_payment_color }};
$footer-copyright-color: {{ settings.footer_copyright_color }};

footer.footer {
    background: #f2f3f5;
    padding: 85px 0px;

    .footer-navigation {
        display: table;
        padding: 0;
        margin-left: auto;
        margin-right: auto;
        margin-bottom: 40px;

        li {
            list-style-type: none;
            float: left;
            margin-left: 25px;
            font-size: 14px;
            font-weight: bold;

            a {
                color: $footer-link-color;
                text-transform: uppercase;
                letter-spacing: 1px;

                @media screen and (max-width: 768px) {
                    padding: 10px 0px;
                    display: block;
                    text-align: center;
                }
            }

            &:first-child {
                margin-left: 0px;
            }

            @media screen and (max-width: 768px) {
                float: none;
                margin: 0;
                border-top: 1px solid #e8eced;
            }
        }

        @media screen and (max-width: 768px) {
            display: block;
        }
    }

    .accepted-payments {
        clear: both;
        display: table;
        position: relative;
        padding: 40px 0px;
        margin-left: auto;
        margin-right: auto;
        margin-top: 40px;
        margin-bottom: 40px;
        border-top: 1px solid $footer-borders-color;
        border-bottom: 1px solid $footer-borders-color;
        width: 100%;

    {% assign social_nr = 0 %}

        {% if settings.show_facebook %}
          {% assign social_nr = 1 %}
        {% endif %}

        {% if settings.show_twitter %}
          {% assign social_nr = social_nr | plus:1 %}
        {% endif %}

        {% if settings.show_google %}
          {% assign social_nr = social_nr | plus:1 %}
        {% endif %}

        {% if settings.show_pinterest %}
          {% assign social_nr = social_nr | plus:1 %}
        {% endif %}

        {% if settings.show_instagram %}
          {% assign social_nr = social_nr | plus:1 %}
        {% endif %}

        {% if social_nr == 0 %}
          {% assign percentage = 100 %}
        {% else %}
          {% assign percentage = 100 | divided_by: social_nr %}
        {% endif %}

        li {
            list-style-type: none;
            float: left;
            font-size: 38px;
            width: {{ percentage }}%;
            text-align: center;

            a {
                color: $footer-social-color;
            }

            &:first-child {
                margin-left: 0px;
            }

            @media screen and (max-width: 768px) {
                font-size: 26px;
            }
        }
    }

    .copyright {
        clear: both;
        margin-top: 40px;

        p {
            text-align: center;
            color: #979797;
            font-size: 14px;

            a {
        		font-size: 18px;
                padding: 2px;
                color: $footer-payment-color;
            }

            span {
              font-size: 13px;
              color: $footer-copyright-color;
            }
        }
    }
}



