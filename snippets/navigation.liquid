{% comment %}
  Navigation
{% endcomment %}
<div class="nav-container">
    <nav class="navbar navbar-default">
        <div class="container">
            <!-- Brand and toggle get grouped for better mobile display -->
            <div class="navbar-header" itemscope itemtype="http://schema.org/Organization">
                <button type="button" class="navbar-toggle collapsed" data-toggle="collapse" data-target="#collapse-navigation" aria-expanded="false">
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
                <span class="icon-bar"></span>
                </button>
                {% assign logo_text = settings.logo_text %}
                {% if settings.logo_text_image == "text" %}
                  <a class="navbar-brand text-logo" href="/" itemprop="url">{{ logo_text }}{% if settings.show_logo_dot %}<span class="logo-dot accent-bg"></span>{% endif %}</a>
                {% else %}
                <a class="navbar-brand image-logo" href="/" itemprop="url"><img src="{{ 'logo.png' | asset_url }}" alt="Logo"></a>
                {% endif %}

                <a href="#sidr" class="side-menu-opener mobile">
                    <div class="bars">
                        <span class="bar top"></span>
                        <span class="bar middle"></span>
                        <span class="bar bottom"></span>
                    </div>
                </a>
                <a href="/search" class="search-icon mobile"><i class="fa fa-search"></i></a>
            </div>

            <!-- Collect the nav links, forms, and other content for toggling -->
            <div class="collapse navbar-collapse" id="collapse-navigation">
                <ul class="nav navbar-nav">

                  {% for link in linklists.main-menu.links %}
                    {% comment %}
                      Create a dropdown menu by naming a linklist the same as a link in the parent nav

                      More info on dropdowns:
                        - http://docs.shopify.com/manual/your-website/navigation/create-drop-down-menu
                    {% endcomment %}
                    {% assign child_list_handle = link.title | handleize %}
                    {% if linklists[child_list_handle].links != blank %}
          			  <li class="dropdown {% if link.active %} active{% endif %}">
                        <a href="{{ link.url }}" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-haspopup="true" aria-expanded="true">{{ link.title }} <span class="fa fa-angle-down"></span></a>
                        <ul class="dropdown-menu">
                            {% for childlink in linklists[child_list_handle].links %}
                              <li class="{% if childlink.active %} active{% endif %}"><a href="{{ childlink.url }}">{{ childlink.title | escape }}</a></li>
                            {% endfor %}
                        </ul>
                      </li>

                    {% else %}
                      <li class="{% if link.active %} active{% endif %}">
                          <a href="{{ link.url }}">{{ link.title }}</a>
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
                <ul class="nav navbar-nav navbar-right">
                    <li><a href="/search"><i class="fa fa-search"></i></a></li>
                      <li id="cart-menu-item"><a href="/cart" class="menu-cart"><i class="fa fa-shopping-cart"></i> <span>{{ cart.total_price | money }}</span></a></li>
                    <li>
                          <a href="#sidr" class="side-menu-opener">
                              <div class="bars">
                                  <span class="bar top"></span>
                                  <span class="bar middle"></span>
                                  <span class="bar bottom"></span>
                              </div>
                          </a>
                      </li>
              </ul>
            </div><!-- /.navbar-collapse -->
        </div><!-- /.container -->
    </nav>
</div>