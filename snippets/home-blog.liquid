{% assign blog = blogs[settings.home_blog] %}

<div class="container">
  {% if settings.home_blog_title_show %}
  <div class="row">
    <div class="col-md-12">
      <div class="section-title">
        <div class="title-sep-container title-sep-container-left">
          <div class="title-sep"></div>
       	</div>
      	<h2 class="page-title h1-size text-center">{{ settings.home_blog_article_title }}</h2>
        <div class="title-sep-container title-sep-container-right">
          <div class="title-sep"></div>
       	</div>
      </div>
      <p class="section-subtitle">{{ settings.home_blog_article_subtitle }}</p>
    </div>
  </div>
  {% endif %}
  <div class="row">
    {% for article in blog.articles limit:3 %}
      <div class="col-md-4">
        <div class="blog-item">
          <div class="blog-item-wrapper">
            {% if article.image %}
                {% assign article_image = article | img_url: 'grande' %}
            	<div class="featured-image">
                  <a href="{{ article.url }}">
                    <img src="{{article_image}}" alt="{{article.title}}">
                  </a>
            	</div>
            {% endif %}
            
            <div class="main_content">
              <h3>
                <a href="{{ article.url }}">{{article.title}}</a>
              </h3>
              <div class="content-bottom">
                <span class="midle_content">
                  <span class="date">on {{ article.created_at | date: "%b %d, %Y" }}</span>
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>